{
  "info": {
    "name": "Tickets API",
    "description": "API REST para administración de tickets y dispositivos",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/register",
              "host": ["{{base_url}}"],
              "path": ["register"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('token', jsonData.data.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/me",
              "host": ["{{base_url}}"],
              "path": ["me"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/logout",
              "host": ["{{base_url}}"],
              "path": ["logout"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "List Tickets",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tickets",
              "host": ["{{base_url}}"],
              "path": ["tickets"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Create Ticket",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/tickets",
              "host": ["{{base_url}}"],
              "path": ["tickets"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Keyboard not working\",\n  \"description\": \"The keyboard stopped responding\",\n  \"priority\": \"medium\"\n}"
            }
          }
        },
        {
          "name": "Get Ticket",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tickets/1",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Update Ticket",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/tickets/1",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\",\n  \"priority\": \"low\"\n}"
            }
          }
        },
        {
          "name": "Delete Ticket",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/tickets/1",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Devices",
      "item": [
        {
          "name": "List Devices",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/devices",
              "host": ["{{base_url}}"],
              "path": ["devices"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Create Device",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/devices",
              "host": ["{{base_url}}"],
              "path": ["devices"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Device\",\n  \"device_type\": \"laptop\",\n  \"brand\": \"Dell\",\n  \"serial_number\": \"SN-NEW-001\"\n}"
            }
          }
        },
        {
          "name": "Assign Device",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/devices/assign",
              "host": ["{{base_url}}"],
              "path": ["devices", "assign"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 3,\n  \"device_id\": 3,\n  \"notes\": \"Assignment for new employee\"\n}"
            }
          }
        },
        {
          "name": "Return Device",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/devices/return/1",
              "host": ["{{base_url}}"],
              "path": ["devices", "return", "1"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Get Device",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/devices/1",
              "host": ["{{base_url}}"],
              "path": ["devices", "1"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Device History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/devices/1/history",
              "host": ["{{base_url}}"],
              "path": ["devices", "1", "history"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ]
}
